    "def get_primes_to_n(n):\n",
    "    for i in range(2, n):\n",
    "        if is_prime(i):\n",
    "            yield i\n",
    "\n",
    "def approximation(n):\n",
    "    prod = 1 \n",
    "    res = prod\n",
    "    for i in get_primes_to_n(n):\n",
    "        prod *= (1 - 1/i**2)\n",
    "        res = 1 / prod\n",
    "        res *= 6 \n",
    "        yield sqrt(res)\n",
    "\n",
    "def create_graph(n):\n",
    "    gen = approximation(n)\n",
    "    \n",
    "    y_vals = list(gen)\n",
    "    x_vals = list(range(1, len(y_vals) + 1))\n",
    "\n",
    "    fig, ax = plt.subplots()\n",
    "    ax.plot(x_vals, y_vals, color=\"b\", label=\"Euler Product Approximation\")\n",
    "    ax.axhline(y=pi, color=\"r\", linestyle='--', label=r\"$y = \\pi$\")\n",
    "    \n",
    "    ax.set_title(rf\"Approximation of $\\pi$ over {n} iterations\")\n",
    "    ax.set_xlabel(\"Number of primes\")\n",
    "    ax.set_ylabel(\"Value\")\n",
    "    ax.legend()\n",
    "    \n",
    "    ax.set_ylim(3.0, 3.2) \n",
    "    plt.show()\n",
    "\n",
    "create_graph(100)"
   ]
